<!doctype html>
<!-- Template: filled by the codelens skill scripts via literal {{TOKEN}} string
     substitution. Kept a valid Jinja subset (no filters or blocks); if ever
     rendered with a Jinja engine, disable autoescape or mark {{D3}}/{{DATA}}
     safe, since both must emit raw HTML/JS. -->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{TITLE}}</title>
    <style>
      :root {
        color-scheme: light dark;
      }
      html,
      body {
        margin: 0;
        height: 100%;
        font:
          13px system-ui,
          sans-serif;
      }
      body {
        display: flex;
        flex-direction: column;
        background: #0b0d12;
        color: #e6e8ec;
      }
      header {
        padding: 8px 12px;
        font-weight: 600;
      }
      header span {
        opacity: 0.6;
        font-weight: 400;
      }
      #chart {
        flex: 1;
      }
      .tip {
        position: fixed;
        pointer-events: none;
        opacity: 0;
        background: #1b1f27;
        border: 1px solid #333;
        border-radius: 6px;
        padding: 6px 8px;
        font-size: 12px;
        max-width: 320px;
        transition: opacity 0.1s;
      }
      .link {
        stroke: #667;
        stroke-opacity: 0.5;
      }
      .node {
        stroke: #0b0d12;
        stroke-width: 1.2px;
        cursor: grab;
      }
      .label {
        fill: #cdd2da;
        font-size: 10px;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <header>{{TITLE}} <span>{{SUBTITLE}}</span></header>
    <div id="chart"></div>
    <div class="tip" id="tip"></div>
    {{D3}}
    <script>
      const graph = {{DATA}};

      const width = 1000, height = 720;
      const groups = [...new Set(graph.nodes.map(n => n.group ?? ""))];
      const color = d3.scaleOrdinal(groups, d3.schemeTableau10);
      const r = d3.scaleSqrt([0, d3.max(graph.nodes, n => n.val || 1) || 1], [4, 28]);
      const lw = d3.scaleLinear([0, d3.max(graph.links, l => l.value || 1) || 1], [0.5, 6]);

      const svg = d3.select("#chart").append("svg")
        .attr("viewBox", [0, 0, width, height])
        .attr("width", width).attr("height", height)
        .style("max-width", "100%").style("height", "auto");
      const g = svg.append("g");
      svg.call(d3.zoom().scaleExtent([0.2, 8]).on("zoom", e => g.attr("transform", e.transform)));

      const tip = d3.select("#tip");

      const sim = d3.forceSimulation(graph.nodes)
        .force("link", d3.forceLink(graph.links).id(d => d.id).distance(60).strength(d => Math.min(1, (d.value || 1) / 100)))
        .force("charge", d3.forceManyBody().strength(-180))
        .force("center", d3.forceCenter(width / 2, height / 2))
        .force("collide", d3.forceCollide().radius(d => r(d.val || 1) + 2));

      const link = g.append("g").selectAll("line")
        .data(graph.links).join("line")
          .attr("class", "link").attr("stroke-width", d => lw(d.value || 1));

      const node = g.append("g").selectAll("circle")
        .data(graph.nodes).join("circle")
          .attr("class", "node").attr("r", d => r(d.val || 1))
          .attr("fill", d => color(d.group ?? ""))
          .call(drag(sim))
          .on("mouseover", (e, d) => tip.style("opacity", 1)
            .html(`<b>${d.id}</b>` + (d.group ? `<br>${d.group}` : "") + (d.val != null ? `<br>weight ${d.val}` : "")))
          .on("mousemove", e => tip.style("left", (e.clientX + 12) + "px").style("top", (e.clientY + 12) + "px"))
          .on("mouseout", () => tip.style("opacity", 0));

      const label = g.append("g").selectAll("text")
        .data(graph.nodes).join("text")
          .attr("class", "label").attr("dx", 6).attr("dy", 3)
          .text(d => d.label ?? d.id);

      sim.on("tick", () => {
        link.attr("x1", d => d.source.x).attr("y1", d => d.source.y)
            .attr("x2", d => d.target.x).attr("y2", d => d.target.y);
        node.attr("cx", d => d.x).attr("cy", d => d.y);
        label.attr("x", d => d.x).attr("y", d => d.y);
      });

      function drag(sim) {
        return d3.drag()
          .on("start", (e, d) => { if (!e.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
          .on("drag", (e, d) => { d.fx = e.x; d.fy = e.y; })
          .on("end", (e, d) => { if (!e.active) sim.alphaTarget(0); d.fx = null; d.fy = null; });
      }
    </script>
  </body>
</html>
